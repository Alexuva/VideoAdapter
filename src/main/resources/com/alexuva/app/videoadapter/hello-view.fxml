<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="700.0" spacing="20.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.alexuva.app.videoadapter.VideoAdapterController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label alignment="TOP_CENTER" graphicTextGap="5.0" text="StarkFamily VideoAdapter" textAlignment="CENTER">
        <font>
            <Font name="Gilroy-ExtraBold" size="34.0" />
        </font>
    </Label>

    <HBox alignment="CENTER" spacing="10.0" maxWidth="420.0">
        <TextField fx:id="filePathField" editable="false" promptText="Selecciona un archivo" HBox.hgrow="ALWAYS"/>
        <Button onAction="#selectFile" text="Examinar"/>
    </HBox>

    <TextField fx:id="debugText" visible="true"></TextField>

    <VBox fx:id="videoInfo" maxWidth="420.0" maxHeight="250" visible="false">
        <Label styleClass="video-info-title" text="Información del vídeo">
            <font>
                <Font name="Gilroy-regular" size="18.0" />
            </font>
        </Label>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxHeight="250.0" styleClass="video-info-container">
            <VBox fx:id="videoInfoContainer" spacing="10.0" />
        </ScrollPane>
    </VBox>

    <VBox fx:id="progressBox" alignment="CENTER" spacing="10" visible="false">
        <ProgressBar fx:id="progressBar" prefWidth="400" progress="0" />
        <Label fx:id="progressLabel" text="0%" />
    </VBox>

    <HBox fx:id="setup" alignment="CENTER" spacing="10" visible="false">
        <ComboBox fx:id="modeSelector" promptText="Selecciona modo" prefHeight="26" />
        <CheckBox fx:id="preserveHDR" text="¿Preservar HDR?" prefHeight="26" disable="true"/>
    </HBox>

    <Button fx:id="convertBtn" onAction="#convert" styleClass="convert-button" text="Convertir" visible="false"/>
    <Button fx:id="cancelBtn" onAction="#cancel" styleClass="cancel-button" text="Cancelar" visible="false"/>

    <Label fx:id="successText" textFill="green" visible="false" text="Conversión completada">
        <font>
            <Font name="Gilroy-Regular" size="15.0" />
        </font>
    </Label>

    <Label fx:id="errorText" textFill="#ab0000" visible="false">
        <font>
            <Font name="Gilroy-Regular" size="15.0" />
        </font>
    </Label>

</VBox>
